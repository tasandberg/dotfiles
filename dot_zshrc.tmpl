# ~/.zshrc — managed by chezmoi
# Config is split into ~/.config/shell/ for organization.

export ZSH="$HOME/.oh-my-zsh"

# Load shell config
source ~/.config/shell/prompt.zsh
source ~/.config/shell/variables.zsh

# Oh My Zsh (after prompt + variables are set)
plugins=(git)
source $ZSH/oh-my-zsh.sh

# Aliases + tools
source ~/.config/shell/aliases.zsh
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Local overrides (not tracked by chezmoi)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
